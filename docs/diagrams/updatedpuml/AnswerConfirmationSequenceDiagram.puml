@startuml
!include ../style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "ac:AnswerConfirmationCommand" as AnswerConfirmationCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("Y")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("Y")
activate AddressBookParser

create AnswerConfirmationCommand
AddressBookParser -> AnswerConfirmationCommand : new AnswerConfirmationCommand(YES)
activate AnswerConfirmationCommand
AnswerConfirmationCommand --> AddressBookParser
deactivate AnswerConfirmationCommand

AddressBookParser --> LogicManager : ac
deactivate AddressBookParser

LogicManager -> AnswerConfirmationCommand : execute(m)
activate AnswerConfirmationCommand

AnswerConfirmationCommand -> Model : getPendingCommand()
activate Model
Model --> AnswerConfirmationCommand : innerCmd
deactivate Model

alt User confirmed (Y)
    note over AnswerConfirmationCommand : Returns innerCmd.execute(m)\n
else User cancelled (N)
    note over AnswerConfirmationCommand : Returns CommandResult\n("Command Cancelled!")
end

AnswerConfirmationCommand --> LogicManager : r
deactivate AnswerConfirmationCommand

LogicManager -> Model : setPendingCommand(null)
activate Model
Model --> LogicManager
deactivate Model

[<-- LogicManager : r
deactivate LogicManager

@enduml
